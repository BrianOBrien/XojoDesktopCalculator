#tag WindowCode
	#tag Event
		Sub Opening()
		  Accumulator = "0"
		  FNT18X21Display1.SetDisplayValue(Accumulator)
		  FNT18X21Display1.RefreshDisplay
		End Sub
	#tag EndEvent


	#tag Method, Flags = &h0
		Function Accumulator() As String
		  if mAccumulator = "" then Accumulator = "0"
		  var lft as String = mAccumulator.LeftPad(8)
		  lft = lft.Right(8)
		  return lft
		  
		  
		End Function
	#tag EndMethod

	#tag Method, Flags = &h0
		Sub Accumulator(assigns value as String)
		  mAccumulator = value
		End Sub
	#tag EndMethod

	#tag Method, Flags = &h0
		Function AppendDigit(acc As String, digit As String) As String
		  // If accumulator is "0", replace it
		  If acc.Trim = "0" Then
		    Return digit
		  End If
		  
		  Return acc + digit
		End Function
	#tag EndMethod

	#tag Method, Flags = &h0
		Function EvaluatePostfix(tokens() As String) As Double
		  Var stack() As Double
		  
		  For Each tok As String In tokens
		    
		    // Normalize GUI operators
		    If tok = "×" Then tok = "*"
		    If tok = "÷" Then tok = "/"
		    
		    If IsNumber(tok) Then
		      stack.Add(tok.ToDouble)
		      
		    ElseIf IsOperator(tok) Then
		      
		      If stack.Count < 2 Then
		        Raise New RuntimeException("Invalid expression.")
		      End If
		      
		      Var b As Double = stack(stack.LastIndex)
		      stack.RemoveAt(stack.LastIndex)
		      
		      Var a As Double = stack(stack.LastIndex)
		      stack.RemoveAt(stack.LastIndex)
		      
		      Var result As Double
		      
		      Select Case tok
		      Case "+"
		        result = a + b
		        
		      Case "-"
		        result = a - b
		        
		      Case "*"
		        result = a * b
		        
		      Case "/"
		        If b = 0 Then Raise New RuntimeException("Divide by zero.")
		        result = a / b
		        
		      Case "^"
		        result = a ^ b
		        
		      Else
		        Raise New RuntimeException("Unknown operator: " + tok)
		      End Select
		      
		      stack.Add(result)
		      
		    Else
		      Raise New RuntimeException("Invalid token: " + tok)
		    End If
		    
		  Next
		  
		  If stack.Count <> 1 Then
		    Raise New RuntimeException("Invalid postfix expression.")
		  End If
		  
		  Return stack(0)
		End Function
	#tag EndMethod

	#tag Method, Flags = &h0
		Function InfixToPostfix(expr As String) As String()
		  Var output() As String
		  Var opStack() As String
		  Var tokens() As String = TokenizeInfix(expr)
		  
		  For Each tok As String In tokens
		    If IsNumber(tok) Or IsIdentifier(tok) Then
		      output.Add(tok)
		      
		    ElseIf tok = "(" Then
		      opStack.Add(tok)
		      
		    ElseIf tok = ")" Then
		      While opStack.Count > 0 And opStack(opStack.LastIndex) <> "("
		        output.Add(opStack(opStack.LastIndex))
		        opStack.RemoveAt(opStack.LastIndex)
		      Wend
		      
		      If opStack.Count = 0 Then
		        Raise New RuntimeException("Mismatched parentheses.")
		      End If
		      
		      opStack.RemoveAt(opStack.LastIndex) ' remove "("
		      
		    ElseIf IsOperator(tok) Then
		      While opStack.Count > 0 _
		        And IsOperator(opStack(opStack.LastIndex)) _
		        And ( _
		        (IsLeftAssociative(tok) And Precedence(tok) <= Precedence(opStack(opStack.LastIndex))) _
		        Or _
		        (Not IsLeftAssociative(tok) And Precedence(tok) < Precedence(opStack(opStack.LastIndex))) _
		        )
		        
		        output.Add(opStack(opStack.LastIndex))
		        opStack.RemoveAt(opStack.LastIndex)
		      Wend
		      
		      opStack.Add(tok)
		      
		    Else
		      Raise New RuntimeException("Unknown token: " + tok)
		    End If
		  Next
		  
		  While opStack.Count > 0
		    If opStack(opStack.LastIndex) = "(" Or opStack(opStack.LastIndex) = ")" Then
		      Raise New RuntimeException("Mismatched parentheses.")
		    End If
		    
		    output.Add(opStack(opStack.LastIndex))
		    opStack.RemoveAt(opStack.LastIndex)
		  Wend
		  
		  Return output
		End Function
	#tag EndMethod

	#tag Method, Flags = &h21
		Private Function IsDigit(ch As String) As Boolean
		  Return ch >= "0" And ch <= "9"
		End Function
	#tag EndMethod

	#tag Method, Flags = &h21
		Private Function IsIdentifier(tok As String) As Boolean
		  If tok = "" Then Return False
		  
		  Var first As String = tok.Left(1)
		  If Not (IsLetter(first) Or first = "_") Then Return False
		  
		  For i As Integer = 1 To tok.Length - 1
		    Var ch As String = tok.Middle(i, 1)
		    If Not (IsLetter(ch) Or IsDigit(ch) Or ch = "_") Then
		      Return False
		    End If
		  Next
		  
		  Return True
		End Function
	#tag EndMethod

	#tag Method, Flags = &h21
		Private Function IsLeftAssociative(op As String) As Boolean
		  Select Case op
		  Case "^"
		    Return False
		  Else
		    Return True
		  End Select
		End Function
	#tag EndMethod

	#tag Method, Flags = &h21
		Private Function IsLetter(ch As String) As Boolean
		  Return (ch >= "A" And ch <= "Z") Or (ch >= "a" And ch <= "z")
		End Function
	#tag EndMethod

	#tag Method, Flags = &h21
		Private Function IsNumber(tok As String) As Boolean
		  If tok = "" Then Return False
		  
		  Var dotCount As Integer = 0
		  
		  For i As Integer = 0 To tok.Length - 1
		    Var ch As String = tok.Middle(i, 1)
		    
		    If ch = "." Then
		      dotCount = dotCount + 1
		      If dotCount > 1 Then Return False
		    ElseIf Not IsDigit(ch) Then
		      Return False
		    End If
		  Next
		  
		  Return True
		End Function
	#tag EndMethod

	#tag Method, Flags = &h21
		Private Function IsOperator(tok As String) As Boolean
		  Return tok = "+" Or tok = "-" Or tok = "*" Or tok = "/" Or tok = "÷" Or tok = "^"
		End Function
	#tag EndMethod

	#tag Method, Flags = &h21
		Private Function Precedence(op As String) As Integer
		  Select Case op
		  Case "+", "-"
		    Return 1
		  Case "*", "/", "÷"
		    Return 2
		  Case "^"
		    Return 3
		  Else
		    Return 0
		  End Select
		End Function
	#tag EndMethod

	#tag Method, Flags = &h0
		Sub SendMessage(d as Dictionary)
		  // Part of the aModule.anInterface interface.
		  
		  
		End Sub
	#tag EndMethod

	#tag Method, Flags = &h21
		Private Function TokenizeInfix(expr As String) As String()
		  Var tokens() As String
		  Var i As Integer = 0
		  
		  While i < expr.Length
		    Var ch As String = expr.Middle(i, 1)
		    
		    If ch = " " Or ch = Chr(9) Then
		      i = i + 1
		      
		    ElseIf IsDigit(ch) Or ch = "." Then
		      Var startPos As Integer = i
		      i = i + 1
		      
		      While i < expr.Length
		        Var c As String = expr.Middle(i, 1)
		        If IsDigit(c) Or c = "." Then
		          i = i + 1
		        Else
		          Exit
		        End If
		      Wend
		      
		      tokens.Add(expr.Middle(startPos, i - startPos))
		      
		    ElseIf IsLetter(ch) Or ch = "_" Then
		      Var startPos As Integer = i
		      i = i + 1
		      
		      While i < expr.Length
		        Var c As String = expr.Middle(i, 1)
		        If IsLetter(c) Or IsDigit(c) Or c = "_" Then
		          i = i + 1
		        Else
		          Exit
		        End If
		      Wend
		      
		      tokens.Add(expr.Middle(startPos, i - startPos))
		      
		    ElseIf ch = "+" Or ch = "-" Or ch = "*" Or ch = "/" Or ch = "÷" Or ch = "^" Or ch = "(" Or ch = ")" Then
		      tokens.Add(ch)
		      i = i + 1
		      
		    Else
		      Raise New RuntimeException("Invalid character: " + ch)
		    End If
		  Wend
		  
		  Return tokens
		End Function
	#tag EndMethod


	#tag Property, Flags = &h21
		Private mAccumulator As String
	#tag EndProperty


