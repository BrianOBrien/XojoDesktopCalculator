#tag Events ButtonEqual
	#tag Event
		Sub Pressed()
		  //Var p() As String = InfixToPostfix(Accumulator)
		  //var res as Double = EvaluatePostfix(p)
		  
		  //Accumulator = res.ToString
		  //FNT18X21Display1.SetDisplayValue(Accumulator)
		  //FNT18X21Display1.RefreshDisplay
		  
		  
		  Try
		    Var tokens() As String = InfixToPostfix(mAccumulator)
		    Var result As Double = EvaluatePostfix(tokens)
		    
		    mAccumulator = result.ToString
		    
		  Catch e As RuntimeException
		    
		    // Show something user-friendly
		    mAccumulator = "0"
		    MessageBox("error")
		    // Optional: log the real reason for debugging
		    //System.DebugLog(e.Message)
		  Finally
		    
		    FNT18X21Display1.SetDisplayValue(Accumulator)
		    FNT18X21Display1.RefreshDisplay
		    
		  End Try
		End Sub
	#tag EndEvent
#tag EndEvents
